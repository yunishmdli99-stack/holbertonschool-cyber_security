#!/usr/bin/env bash
# This script loops indefinitely and yields a message on SIGTERM

# Trap SIGTERM: print the message and then exit
trap 'echo "I am invincible!!!"; exit' SIGTERM

while true; do
    echo "To infinity and beyond"
    # Sleep in background so the shell stays 'interactive' to signals
    sleep 2 &
    # Wait for the background sleep process
    wait $!
done
